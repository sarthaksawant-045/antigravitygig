# PostgreSQL Database Configuration
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
BACKEND_URL=http://127.0.0.1:5000
FRONTEND_BASE_URL=http://localhost:5173

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Leave GOOGLE_REDIRECT_URI unset to auto-derive it from BACKEND_URL in app.py.
# Local example: http://127.0.0.1:5000/auth/google/callback
# Hosted example: https://your-backend-domain.com/auth/google/callback
GOOGLE_REDIRECT_URI=

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_sender_email_here
EMAIL_PASSWORD=your_email_app_password_here
GIGBRIDGE_SENDER_EMAIL=your_sender_email_here
GIGBRIDGE_APP_PASSWORD=your_email_app_password_here

# Security
SECRET_KEY=your_secret_key_here_change_this_in_production
